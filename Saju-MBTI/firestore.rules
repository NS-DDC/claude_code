rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection - each user can only access their own data
    match /users/{userId} {
      // Users can read and write their own user document
      allow read, write: if isOwner(userId);

      // History subcollection - user's fortune/MBTI records
      match /history/{recordId} {
        // Users can read, create, update, and delete their own history
        allow read, write: if isOwner(userId);

        // Validate that the record has required fields
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasAll(['type', 'createdAt'])
          && request.resource.data.type in ['saju', 'mbti', 'scan', 'daily'];
      }

      // Preferences subcollection - user's app preferences
      match /preferences/{docId} {
        // Users can read and write their own preferences
        allow read, write: if isOwner(userId);

        // Ensure preferences document has valid structure
        allow create, update: if isOwner(userId)
          && request.resource.data.keys().hasAny(['mbti', 'element', 'birthInfo', 'notificationSettings', 'theme']);
      }

      // Notification settings subcollection
      match /notificationSettings/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
