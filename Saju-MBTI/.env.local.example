# Firebase Configuration
#
# To get these values:
# 1. Go to Firebase Console (https://console.firebase.google.com/)
# 2. Select your project
# 3. Click on the gear icon (Project Settings)
# 4. Scroll down to "Your apps" section
# 5. Click on the web app or create a new web app
# 6. Copy the config values from the Firebase SDK snippet
#
# After getting your values:
# 1. Copy this file to .env.local
# 2. Replace all placeholder values with your actual Firebase config values
# 3. Never commit .env.local to version control

# Firebase API Key - Used for authentication and API access
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here

# Firebase Auth Domain - Used for authentication
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com

# Firebase Project ID - Your Firebase project identifier
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# Firebase Storage Bucket - Used for file storage
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Firebase Messaging Sender ID - Used for Cloud Messaging
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id

# Firebase App ID - Your Firebase application identifier
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Sentry Configuration (Optional - for error monitoring)
#
# To get your Sentry DSN:
# 1. Go to https://sentry.io and create a free account
# 2. Create a new project (select Next.js as platform)
# 3. Copy the DSN from the project settings
# 4. Paste it below
#
# Note: Sentry is optional. The app will work fine without it.
# Error monitoring is only enabled in production builds.
#
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-key@o0.ingest.sentry.io/0000000
